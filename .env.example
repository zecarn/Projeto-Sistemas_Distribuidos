# Usadas pelo Docker Compose para criar e publicar os serviços.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=biblioteca_db
POSTGRES_PORT=5432
APP_PORT=3000

# Fora do Docker, a aplicação acessa o PostgreSQL publicado em localhost.
# Dentro do Docker, o Compose sobrescreve esta variável usando o host "postgres".
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/biblioteca_db?schema=public"
